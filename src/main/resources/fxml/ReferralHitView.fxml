<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="774.0" stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ReferralHitController">
    <children>
        <VBox prefHeight="768.0" prefWidth="500.0" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="title-label" text="Referral Hits Log">
                    <VBox.margin>
                        <Insets bottom="10.0" left="20.0" top="20.0" />
                    </VBox.margin>
                </Label>
                
                <HBox spacing="20.0">
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                    <children>
                        <VBox styleClass="card" prefWidth="200.0" alignment="CENTER" prefHeight="80.0">
                            <children>
                                <Label styleClass="subtitle-label" text="Total Hits" />
                                <Label fx:id="lblTotalHits" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #BB86FC;" text="0" />
                            </children>
                        </VBox>
                        <VBox styleClass="card" prefWidth="200.0" alignment="CENTER" prefHeight="80.0">
                            <children>
                                <Label styleClass="subtitle-label" text="Total Conversions" />
                                <Label fx:id="lblConversions" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #03DAC6;" text="0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <TableView fx:id="tableHits" prefHeight="550.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colInfluencer" prefWidth="100.0" text="Influencer ID" />
                        <TableColumn fx:id="colSession" prefWidth="150.0" text="Session ID" />
                        <TableColumn fx:id="colDate" prefWidth="150.0" text="Visited At" />
                        <TableColumn fx:id="colReferred" prefWidth="100.0" text="Referred User" />
                    </columns>
                    <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </VBox.margin>
                </TableView>
            </children>
        </VBox>
        <VBox prefHeight="768.0" prefWidth="250.0" styleClass="card">
            <HBox.margin>
                <Insets bottom="20.0" right="20.0" top="20.0" />
            </HBox.margin>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Simulate Web Traffic">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>
                
                <Label text="Influencer ID" />
                <TextField fx:id="txtInfluencerId" promptText="e.g. 101" />
                
                <Label text="Simulated Session ID">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtSessionId" editable="false" promptText="Auto-generated" />
                <Button mnemonicParsing="false" onAction="#handleGenerateSession" text="Generate New Session">
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Button>
                
                <Label text="Referred User ID (Optional)">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtReferredUserId" promptText="Left blank if just a view" />
                
                <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSimulateView" styleClass="btn-primary" text="Simulate View (Hit)" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSimulateConversion" styleClass="btn-success" text="Simulate Conversion" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
