<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox styleClass="front-page" spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FrontPromoController">
    <!-- Glassmorphism Sidebar -->
    <VBox prefWidth="240.0" spacing="20.0" styleClass="promo-sidebar">
        <padding><Insets bottom="30.0" left="20.0" right="20.0" top="30.0" /></padding>
        <Label styleClass="sidebar-section-title" text="CATEGORIES" />
        <VBox spacing="10.0">
            <Button fx:id="btnAll" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#filterAll" styleClass="promo-side-btn" text="🌐 All Campaigns" />
            <Button fx:id="btnVideo" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#filterVideo" styleClass="promo-side-btn" text="▶ Video Ads" />
            <Button fx:id="btnImage" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#filterImage" styleClass="promo-side-btn" text="🖼 Image Ads" />
            <Button fx:id="btnAffiche" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#filterAffiche" styleClass="promo-side-btn" text="📜 Affiches" />
        </VBox>
        <Region VBox.vgrow="ALWAYS" />
        <VBox fx:id="partnerHelpBox" spacing="5.0" styleClass="promo-help-box">
            <Label style="-fx-font-weight: bold;" text="Become a Partner?" />
            <Label style="-fx-font-size: 11px;" text="Monetize your events with our ad network." wrapText="true" />
            <Button mnemonicParsing="false" onAction="#handleApply" styleClass="btn-primary-small" text="Apply Now" />
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <!-- Page header & Hero -->
        <VBox styleClass="front-page-header" spacing="15">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="📢  PROMOTIONS &amp; CAMPAIGNS" styleClass="front-page-title"/>
                    <Label text="Premium deals from our verified partners." styleClass="front-page-subtitle"/>
                </VBox>
                <Label fx:id="geoLabel" text="📍  Locating..." styleClass="promo-geo-label"/>
            </HBox>

            <!-- Featured Hero Banner (Optional/Dynamic) -->
            <StackPane fx:id="heroBanner" prefHeight="120.0" styleClass="promo-hero-card">
                <VBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label styleClass="hero-tag" text="FEATURED CAMPAIGN" />
                    <Label fx:id="heroTitleLabel" styleClass="hero-title" text="Expand Your Reach with Evento Ads" />
                    <Label fx:id="heroDescLabel" styleClass="hero-desc" text="Join 50+ partners already growing their business." />
                </VBox>
            </StackPane>
        </VBox>

        <!-- Filters bar -->
        <HBox styleClass="front-filters-bar" spacing="12" alignment="CENTER_LEFT">
             <padding><Insets left="32" right="32" top="15" bottom="15"/></padding>
            <Label text="ACTIVE CAMPAIGNS" styleClass="promo-section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" text="" styleClass="front-count-label"/>
        </HBox>

        <!-- Ad cards grid -->
        <ScrollPane styleClass="front-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="adGrid" styleClass="events-flow-grid" hgap="25" vgap="25">
                <padding><Insets top="10" right="32" bottom="40" left="32"/></padding>
            </FlowPane>
        </ScrollPane>
    </VBox>
</HBox>
