<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Layout: filters + cart (left) · product grid (center) · iTunes trends (right) -->
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FrontShopController"
      styleClass="front-page,shop-root" spacing="0">

    <!-- LEFT: search → filters → all prices (TND) → cart -->
    <VBox styleClass="shop-filter-sidebar" spacing="0" prefWidth="268" minWidth="268">

        <VBox styleClass="shop-filter-header" spacing="6">
            <padding><Insets top="18" right="14" bottom="12" left="14"/></padding>
            <Label text="🛒  SHOP" styleClass="shop-sidebar-brand"/>
            <Label text="Search, filter, see every price in TND" styleClass="shop-sidebar-sub" wrapText="true"/>
        </VBox>

        <Region prefHeight="1" style="-fx-background-color:#E5E7EB;"/>

        <ScrollPane styleClass="front-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox spacing="18" style="-fx-padding:14;">
                <VBox spacing="6">
                    <Label text="SEARCH" styleClass="shop-filter-label"/>
                    <TextField fx:id="searchField" promptText="Artist, product…"
                               styleClass="front-search-field" onKeyReleased="#filterProducts"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="SIZE" styleClass="shop-filter-label"/>
                    <ComboBox fx:id="sizeFilter" styleClass="front-combo" maxWidth="Infinity" onAction="#filterProducts"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="FILTER — MAX PRICE (SCROLL)" styleClass="shop-filter-label"/>
                    <Slider fx:id="priceSlider" min="0" max="500" value="500"
                            onMouseReleased="#filterProducts"/>
                    <Label fx:id="priceLabel" text="500 TND" styleClass="shop-filter-value"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="CURRENCY (DISPLAY)" styleClass="shop-filter-label"/>
                    <ComboBox fx:id="currencyCombo" styleClass="front-combo" maxWidth="Infinity" onAction="#onCurrencyChanged"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="SORT" styleClass="shop-filter-label"/>
                    <ComboBox fx:id="sortFilter" styleClass="front-combo" maxWidth="Infinity" onAction="#filterProducts"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="EXCHANGE RATE" styleClass="shop-filter-label"/>
                    <Label fx:id="rateLabel" text="Fetching rates…" styleClass="shop-rate-label" wrapText="true"/>
                    <Button text="💱  CONVERT PRICES" maxWidth="Infinity"
                            styleClass="btn-secondary" onAction="#onCurrencyChanged"/>
                </VBox>
            </VBox>
        </ScrollPane>

        <Region prefHeight="1" style="-fx-background-color:#E5E7EB;"/>

        <VBox styleClass="shop-cart-mini" spacing="4">
            <padding><Insets top="12" right="14" bottom="14" left="14"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="YOUR CART" styleClass="shop-filter-label"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <ScrollPane styleClass="front-scroll" fitToWidth="true" prefHeight="140" maxHeight="180">
                <VBox fx:id="cartItemsBox" spacing="8" style="-fx-padding:4;"/>
            </ScrollPane>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="cartBadge" text="Cart is empty" styleClass="shop-cart-mini-label"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Subtotal" styleClass="shop-cart-mini-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cartSubtotalLabel" text="0.00 TND" styleClass="shop-cart-mini-label"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Shipping" styleClass="shop-cart-mini-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cartShippingLabel" text="—" styleClass="shop-cart-mini-label"/>
            </HBox>
            <Region prefHeight="2"/>
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="TOTAL" styleClass="shop-filter-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cartTotalLabel" text="0.00 TND" styleClass="shop-cart-total"/>
            </HBox>
            <Label fx:id="cartTotalConverted" text="" styleClass="shop-cart-converted"/>
            <Button fx:id="checkoutBtn" text="CHECKOUT →" styleClass="checkout-btn"
                    maxWidth="Infinity" onAction="#onCheckout"/>
        </VBox>
    </VBox>

    <!-- CENTER: toolbar + grid -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <HBox styleClass="shop-product-toolbar" alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="12" right="24" bottom="12" left="20"/></padding>
            <Label fx:id="countLabel" text="0 products" styleClass="shop-count-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🗑  Clear Cart" styleClass="cart-clear-btn" onAction="#onClearCart"/>
        </HBox>
        <Region prefHeight="1" style="-fx-background-color:#E5E7EB;"/>
        <ScrollPane styleClass="front-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="shopGrid" styleClass="shop-product-grid" hgap="20" vgap="20">
                <padding><Insets top="14" right="24" bottom="28" left="20"/></padding>
            </FlowPane>
        </ScrollPane>
    </VBox>

    <!-- RIGHT: live charts (iTunes RSS) — genres + trending artists -->
    <VBox spacing="0" prefWidth="292" minWidth="292" styleClass="shop-trends-panel">
        <VBox styleClass="shop-filter-header" spacing="4">
            <padding><Insets top="16" right="12" bottom="10" left="12"/></padding>
            <Label text="📈  WHAT’S HOT" styleClass="shop-sidebar-brand" style="-fx-font-size:13px;"/>
            <Label text="Live iTunes charts for your region — steal ideas for drops &amp; bundles."
                   styleClass="shop-rate-label" wrapText="true"/>
        </VBox>
        <Region prefHeight="1" style="-fx-background-color:#E5E7EB;"/>
        <ScrollPane styleClass="front-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox spacing="12" style="-fx-padding:12;">
                <Label text="GENRES ON THE SINGLES CHART" styleClass="shop-filter-label"/>
                <Label fx:id="trendGenreLabel" text="Loading…" styleClass="shop-rate-label" wrapText="true"/>
                <Region prefHeight="4"/>
                <Label text="TRENDING ALBUM ARTISTS" styleClass="shop-filter-label"/>
                <VBox fx:id="trendArtistsBox" spacing="10"/>
                <Label fx:id="trendStatusLabel" text="" styleClass="shop-rate-label" wrapText="true"/>
                <Button text="↻  Refresh charts" styleClass="cart-clear-btn" maxWidth="Infinity" onAction="#onRefreshTrends"/>
            </VBox>
        </ScrollPane>
    </VBox>

</HBox>
