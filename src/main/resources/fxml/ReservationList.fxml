<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ReservationListController"
      spacing="20">

    <VBox spacing="4">
        <Label text="🎟  Reservations" styleClass="page-title"/>
        <Label text="Track tickets, bookings and attendance" styleClass="page-subtitle"/>
        <Region prefHeight="3" prefWidth="100"
                style="-fx-background-color: linear-gradient(to right, #6366F1, #818CF8, transparent); -fx-background-radius: 2;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #0D0F16; -fx-padding: 10 14 10 14; -fx-background-radius: 11; -fx-border-color: #1C2133; -fx-border-radius: 11; -fx-border-width: 1;">
        <TextField fx:id="searchField" promptText="🔍  Search by user ID or event ID…"
                   styleClass="search-field" prefWidth="320"/>
        <ComboBox fx:id="statusFilter" promptText="All statuses" prefWidth="155"/>
        <Button text="Reset" styleClass="btn-ghost" onAction="#onReset"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+  New Reservation" styleClass="btn-success" onAction="#onAdd"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colEvent"   text="EVENT ID"   prefWidth="120"/>
            <TableColumn fx:id="colUser"    text="USER ID"    prefWidth="120"/>
            <TableColumn fx:id="colPlaces"  text="PLACES"     prefWidth="100"/>
            <TableColumn fx:id="colStatut"  text="STATUS"     prefWidth="160"/>
            <TableColumn fx:id="colCreated" text="CREATED AT" prefWidth="180"/>
            <TableColumn fx:id="colActions" text="ACTIONS"    prefWidth="120"/>
        </columns>
    </TableView>

</VBox>
