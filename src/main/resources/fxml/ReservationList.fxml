<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ReservationListController"
      spacing="18">

    <VBox spacing="2">
        <Label text="Reservations" styleClass="page-title"/>
        <Label text="Track tickets and bookings" styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by user ID or event ID..."
                   styleClass="search-field" prefWidth="300"/>
        <ComboBox fx:id="statusFilter" promptText="All statuses" prefWidth="160"/>
        <Button text="Reset" styleClass="btn-ghost" onAction="#onReset"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New Reservation" styleClass="btn-success" onAction="#onAdd"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colEvent" text="EVENT ID" prefWidth="100"/>
            <TableColumn fx:id="colUser" text="USER ID" prefWidth="100"/>
            <TableColumn fx:id="colPlaces" text="PLACES" prefWidth="90"/>
            <TableColumn fx:id="colStatut" text="STATUS" prefWidth="120"/>
            <TableColumn fx:id="colCreated" text="CREATED AT" prefWidth="160"/>
            <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="180"/>
        </columns>
    </TableView>

</VBox>
