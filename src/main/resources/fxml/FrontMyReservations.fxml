<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FrontMyReservationsController"
      styleClass="front-page"
      spacing="0">

    <VBox styleClass="front-page-header" spacing="6">
        <Label text="🎟  MY TICKETS" styleClass="front-page-title"/>
        <Label text="Your reserved shows. Don't miss a single riff." styleClass="front-page-subtitle"/>
    </VBox>

    <HBox styleClass="front-filters-bar" spacing="12" alignment="CENTER_LEFT">
        <ComboBox fx:id="statusFilter" styleClass="front-combo" prefWidth="160" onAction="#filterTickets"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="ticketCount" text="0 tickets" styleClass="front-count-label"/>
    </HBox>

    <ScrollPane styleClass="front-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="ticketsGrid" styleClass="events-flow-grid" hgap="18" vgap="18">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
        </FlowPane>
    </ScrollPane>

</VBox>
