<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.CategoryFormController"
      styleClass="content-area"
      prefWidth="520" spacing="16">
    <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>

    <VBox spacing="2">
        <Label fx:id="formTitle" text="New Category" styleClass="form-title"/>
        <Label text="Categories help organize products." styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="card" spacing="14">

        <VBox spacing="4">
            <Label text="NAME" styleClass="field-label"/>
            <TextField fx:id="nameField" promptText="e.g. Vinyl, Merchandise, Tickets"/>
        </VBox>

        <VBox spacing="4">
            <Label text="DESCRIPTION" styleClass="field-label"/>
            <TextArea fx:id="descriptionArea" promptText="What kind of products belong here?"
                      prefRowCount="4" wrapText="true"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancel" styleClass="btn-ghost" onAction="#onCancel"/>
            <Button fx:id="saveButton" text="Save category" styleClass="btn-success" onAction="#onSave"/>
        </HBox>
    </VBox>
</VBox>
