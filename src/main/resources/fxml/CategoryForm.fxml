<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CategoryFormController"
            fitToWidth="true" styleClass="form-scroll">
    <content>
        <VBox spacing="22">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="← Back" styleClass="btn-ghost" onAction="#onCancel"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="3">
                <Label fx:id="formTitle" text="New Category" styleClass="page-title"/>
                <Label text="Categories help organize products." styleClass="page-subtitle"/>
            </VBox>
            <VBox styleClass="card" spacing="18">
                <VBox spacing="5">
                    <Label text="NAME" styleClass="field-label"/>
                    <TextField fx:id="nameField" promptText="e.g. Vinyl, Merchandise, Tickets"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="DESCRIPTION" styleClass="field-label"/>
                    <TextArea fx:id="descriptionArea" promptText="What kind of products belong here?" prefRowCount="4" wrapText="true"/>
                </VBox>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Cancel" styleClass="btn-ghost" onAction="#onCancel"/>
                    <Button fx:id="saveButton" text="Save category" styleClass="btn-success" onAction="#onSave"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
