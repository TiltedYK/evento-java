<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="950.0" stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PartnershipRequestController">
    <children>
        <VBox prefHeight="768.0" prefWidth="550.0" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="title-label" text="Partnership Requests">
                    <VBox.margin>
                        <Insets bottom="10.0" left="20.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <TableView fx:id="tableRequests" prefHeight="700.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                        <TableColumn fx:id="colCompany" prefWidth="120.0" text="Company" />
                        <TableColumn fx:id="colContact" prefWidth="100.0" text="Contact" />
                        <TableColumn fx:id="colEmail" prefWidth="140.0" text="Email" />
                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="Status" />
                        <TableColumn fx:id="colDate" prefWidth="100.0" text="Created" />
                    </columns>
                    <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                    </VBox.margin>
                </TableView>
            </children>
        </VBox>
        
        <VBox prefHeight="768.0" prefWidth="350.0" styleClass="card">
            <HBox.margin>
                <Insets bottom="20.0" right="20.0" top="20.0" />
            </HBox.margin>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Manage Request">
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>
                
                <Label text="Company Name" />
                <TextField fx:id="txtCompany" promptText="Enter company name" />
                
                <Label text="Contact Name">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtContact" promptText="Full Name" />
                
                <Label text="Email">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtEmail" promptText="contact@company.com" />
                
                <Label text="Phone">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtPhone" promptText="+1 234 567 890" />
                
                <Label text="Message">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextArea fx:id="txtMessage" prefHeight="80.0" promptText="Partnership details..." wrapText="true" />
                
                <HBox alignment="CENTER" spacing="10.0">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleSave" styleClass="btn-primary" text="Save" />
                        <Button mnemonicParsing="false" onAction="#handleClear" text="Clear">
                           <styleClass>
                              <String fx:value="button" />
                           </styleClass>
                        </Button>
                    </children>
                </HBox>
                
                <Label styleClass="subtitle-label" text="Workflow">
                    <VBox.margin>
                        <Insets top="20.0" bottom="10.0" />
                    </VBox.margin>
                </Label>
                <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAccept" styleClass="btn-success" text="Accept" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleReject" text="Reject">
                            <styleClass>
                                <String fx:value="button" />
                                <String fx:value="btn-danger" />
                            </styleClass>
                        </Button>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-danger" text="Delete">
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
