<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.LoginController"
           prefWidth="1240" prefHeight="760"
           styleClass="login-root">

    <!-- Background -->
    <MediaView fx:id="bgVideo" fitWidth="1240" fitHeight="760"
               preserveRatio="false" opacity="0.25" styleClass="login-bg-video"/>
    <StackPane styleClass="login-overlay"/>
    <VBox styleClass="scan-lines" mouseTransparent="true"/>

    <!-- Shuffle theme + background track (same playlist as the main app). -->
    <HBox StackPane.alignment="TOP_RIGHT" style="-fx-padding:16 20 0 0;" spacing="8"
          alignment="CENTER_RIGHT">
        <Button fx:id="loginThemeToggle" text="🎲" styleClass="login-theme-btn"
                onAction="#toggleLoginTheme"/>
    </HBox>

    <!-- Clock — bottom right -->
    <Label fx:id="clockLabel" text="00:00:00" styleClass="login-corner-label"
           StackPane.alignment="BOTTOM_RIGHT" style="-fx-padding: 0 22 18 0;"/>
    <Label text="[ EVENTO v1.0 ]" styleClass="login-corner-label"
           StackPane.alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 18 22;"/>

    <!-- ── Main card ── -->
    <VBox fx:id="loginCard" alignment="CENTER" spacing="0" maxWidth="400" maxHeight="620"
          styleClass="login-card">

        <!-- Logo (compact) -->
        <VBox alignment="CENTER" spacing="2" styleClass="login-logo-block">
            <Label text="⚡" styleClass="login-bolt"/>
            <Label text="EVENTO" styleClass="login-brand"/>
            <Label text="THE UNDERGROUND STAGE" styleClass="login-tagline"/>
        </VBox>

        <!-- ── LOGIN FORM ── -->
        <VBox fx:id="loginPanel" spacing="11" styleClass="login-form-block">

            <VBox spacing="4">
                <Label text="EMAIL" styleClass="login-field-label"/>
                <TextField fx:id="emailField" promptText="your@email.com" styleClass="login-field"/>
            </VBox>

            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label text="PASSWORD" styleClass="login-field-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="forgotLink" text="Forgot password?" styleClass="login-link"
                           onMouseClicked="#toggleForgot"/>
                </HBox>
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" text="" styleClass="login-error" wrapText="true"/>

            <Button fx:id="loginBtn" text="SIGN IN" styleClass="login-button"
                    onAction="#handleLogin" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding:0 0 0 0;">
                <Label fx:id="forgotBigLink" text="🔑  Forgot your password?  Reset it →"
                       styleClass="login-link" onMouseClicked="#toggleForgot"
                       style="-fx-font-size:11.5px;"/>
            </HBox>

            <!-- "OR" separator between credentials and Google sign-in -->
            <HBox alignment="CENTER" spacing="10" styleClass="login-or-divider">
                <Region HBox.hgrow="ALWAYS" styleClass="login-or-line"/>
                <Label text="OR" styleClass="login-or-text"/>
                <Region HBox.hgrow="ALWAYS" styleClass="login-or-line"/>
            </HBox>

            <Button fx:id="googleBtn"
                    text="🅖   CONTINUE WITH GOOGLE"
                    styleClass="login-google-button"
                    onAction="#handleGoogleLogin"
                    maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding:2 0 0 0;">
                <Label text="New here?" styleClass="login-footer-text"/>
                <Label fx:id="signupLink" text="Create an account →" styleClass="login-link"
                       onMouseClicked="#toggleSignup"/>
            </HBox>
        </VBox>

        <!-- ── FORGOT-PASSWORD PANEL (replaces login form, no popup window) ── -->
        <VBox fx:id="forgotPanel" spacing="11" styleClass="login-form-block"
              visible="false" managed="false">

            <Label text="RESET YOUR PASSWORD" styleClass="login-section-label"/>
            <Label text="We'll send a one-time code so you can choose a new password."
                   styleClass="login-footer-text" wrapText="true"
                   style="-fx-padding:0 0 4 0;"/>

            <!-- Step 1 — email lookup -->
            <VBox fx:id="forgotStep1" spacing="11">
                <VBox spacing="4">
                    <Label text="ACCOUNT EMAIL" styleClass="login-field-label"/>
                    <TextField fx:id="forgotEmail" promptText="your@email.com" styleClass="login-field"/>
                </VBox>

                <Label fx:id="forgotMailReady" text=""
                       styleClass="login-footer-text" wrapText="true"
                       style="-fx-font-size:10px;"/>

                <Button fx:id="forgotSendByMail" text="📧  SEND CODE BY EMAIL"
                        styleClass="login-button" onAction="#sendForgotCodeByMail"
                        maxWidth="Infinity"/>

                <Button fx:id="forgotShowInApp" text="🔑  SHOW CODE IN APP"
                        styleClass="login-google-button" onAction="#showForgotCodeInApp"
                        maxWidth="Infinity"/>
            </VBox>

            <!-- Step 2 — code + new password -->
            <VBox fx:id="forgotStep2" spacing="11" visible="false" managed="false">
                <Label fx:id="forgotCodeBanner" text="" wrapText="true"
                       styleClass="login-success-banner"/>

                <VBox spacing="4">
                    <Label text="6-DIGIT CODE" styleClass="login-field-label"/>
                    <TextField fx:id="forgotCode" promptText="123456" styleClass="login-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="NEW PASSWORD" styleClass="login-field-label"/>
                    <PasswordField fx:id="forgotNewPwd" promptText="At least 6 characters"
                                   styleClass="login-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="CONFIRM PASSWORD" styleClass="login-field-label"/>
                    <PasswordField fx:id="forgotConfirmPwd" promptText="Type it again"
                                   styleClass="login-field"/>
                </VBox>

                <Button fx:id="forgotResetBtn" text="✓  RESET PASSWORD"
                        styleClass="login-button" onAction="#confirmForgotReset"
                        maxWidth="Infinity"/>
            </VBox>

            <Label fx:id="forgotStatus" text="" styleClass="login-error" wrapText="true"/>

            <HBox alignment="CENTER" spacing="6" style="-fx-padding:6 0 0 0;">
                <Label text="←  Back to sign in" styleClass="login-link"
                       onMouseClicked="#toggleForgot"/>
            </HBox>
        </VBox>

        <!-- ── SIGN UP FORM ── -->
        <VBox fx:id="signupPanel" spacing="11" styleClass="login-form-block"
              visible="false" managed="false">

            <Label text="CREATE YOUR ACCOUNT" styleClass="login-section-label"/>

            <HBox spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="FIRST NAME" styleClass="login-field-label"/>
                    <TextField fx:id="signupPrenom" promptText="First name" styleClass="login-field"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="LAST NAME" styleClass="login-field-label"/>
                    <TextField fx:id="signupNom" promptText="Last name" styleClass="login-field"/>
                </VBox>
            </HBox>

            <VBox spacing="4">
                <Label text="EMAIL" styleClass="login-field-label"/>
                <TextField fx:id="signupEmail" promptText="your@email.com" styleClass="login-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="PASSWORD" styleClass="login-field-label"/>
                <PasswordField fx:id="signupPassword" promptText="Min. 6 characters" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ImageView fx:id="captchaImage" fitWidth="200" fitHeight="56"
                               preserveRatio="false" styleClass="login-captcha-img"/>
                    <Button text="↺" styleClass="login-ghost-btn"
                            onAction="#refreshCaptcha" style="-fx-font-size:18px;-fx-padding:6 12 6 12;"/>
                </HBox>
                <TextField fx:id="captchaAnswer" promptText="Type the characters you see"
                           styleClass="login-field"/>
            </VBox>

            <Label fx:id="signupError" text="" styleClass="login-error" wrapText="true"/>
            <Button text="CREATE ACCOUNT" styleClass="login-button"
                    onAction="#handleSignup" maxWidth="Infinity"/>
            <HBox alignment="CENTER" spacing="6" style="-fx-padding:6 0 0 0;">
                <Label text="Already have an account?" styleClass="login-footer-text"/>
                <Label text="Sign in ↑" styleClass="login-link"
                       onMouseClicked="#toggleSignup"/>
            </HBox>
        </VBox>

    </VBox>

</StackPane>
