<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.Media?>
<?import javafx.scene.media.MediaPlayer?>
<?import javafx.scene.media.MediaView?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controller.LoginController"
           prefWidth="1240" prefHeight="760"
           styleClass="login-root">

    <!-- Background video -->
    <MediaView fx:id="bgVideo" fitWidth="1240" fitHeight="760"
               preserveRatio="false" opacity="0.35"
               styleClass="login-bg-video"/>

    <!-- Dark overlay with noise grain feel -->
    <StackPane styleClass="login-overlay"/>

    <!-- Animated scan lines effect -->
    <VBox styleClass="scan-lines" mouseTransparent="true"/>

    <!-- Center card -->
    <VBox alignment="CENTER" spacing="0" maxWidth="440"
          styleClass="login-card"
          fx:id="loginCard">

        <!-- Logo section -->
        <VBox alignment="CENTER" spacing="6" styleClass="login-logo-block">
            <Label text="⚡" styleClass="login-bolt"/>
            <Label text="EVENTO" styleClass="login-brand"/>
            <Label text="THE UNDERGROUND STAGE" styleClass="login-tagline"/>
        </VBox>

        <!-- Divider -->
        <HBox styleClass="login-divider-line">
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="▸ ACCESS REQUIRED ◂" styleClass="login-divider-text"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Form -->
        <VBox spacing="16" styleClass="login-form-block">

            <VBox spacing="6">
                <Label text="EMAIL" styleClass="login-field-label"/>
                <TextField fx:id="emailField"
                           promptText="your@email.com"
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="PASSWORD" styleClass="login-field-label"/>
                <PasswordField fx:id="passwordField"
                              promptText="••••••••"
                              styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" text="" styleClass="login-error" wrapText="true"/>

            <Button fx:id="loginBtn"
                    text="ENTER THE PIT"
                    styleClass="login-button"
                    onAction="#handleLogin"
                    maxWidth="Infinity"/>

        </VBox>

        <!-- Footer -->
        <Label text="No account? Contact the admin." styleClass="login-footer-text"
               style="-fx-padding: 20 0 0 0;"/>

    </VBox>

    <!-- Corner decorations -->
    <Label text="[ EVENTO v1.0 ]" styleClass="login-corner-label"
           StackPane.alignment="BOTTOM_LEFT"
           style="-fx-padding: 0 0 18 22;"/>

    <Label fx:id="clockLabel" text="00:00:00" styleClass="login-corner-label"
           StackPane.alignment="BOTTOM_RIGHT"
           style="-fx-padding: 0 22 18 0;"/>

</StackPane>
