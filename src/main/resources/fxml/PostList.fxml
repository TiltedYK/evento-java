<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.PostListController"
      spacing="22">
    <VBox spacing="3">
        <Label text="Posts" styleClass="page-title"/>
        <Label text="News, announcements and articles" styleClass="page-subtitle"/>
    </VBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Search by title or content..." styleClass="search-field" prefWidth="320"/>
        <ComboBox fx:id="stateFilter" promptText="All posts" prefWidth="160"/>
        <Button text="Reset" styleClass="btn-ghost" onAction="#onReset"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New Post" styleClass="btn-success" onAction="#onAdd"/>
    </HBox>
    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitle"   text="TITLE"   prefWidth="280"/>
            <TableColumn fx:id="colSlug"    text="SLUG"    prefWidth="240"/>
            <TableColumn fx:id="colCreated" text="CREATED" prefWidth="160"/>
            <TableColumn fx:id="colState"   text="STATE"   prefWidth="110"/>
            <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="160"/>
        </columns>
    </TableView>
</VBox>
