<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FrontPartnerHubController"
      styleClass="front-page" spacing="0" prefHeight="768.0" prefWidth="1024.0">

    <VBox prefWidth="650.0" HBox.hgrow="ALWAYS">
        <children>
            <VBox styleClass="front-page-header" spacing="6">
                <Label text="💼  PARTNER HUB" styleClass="front-page-title"/>
                <Label text="Manage your collaborations and track your campaign performance." styleClass="front-page-subtitle"/>
            </VBox>
            
            <TableView fx:id="tableCollaborations" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitle" prefWidth="150.0" text="Campaign Title" />
                    <TableColumn fx:id="colType" prefWidth="100.0" text="Type" />
                    <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                    <TableColumn fx:id="colStartDate" prefWidth="100.0" text="Start Date" />
                    <TableColumn fx:id="colPrice" prefWidth="80.0" text="Price" />
                </columns>
                <VBox.margin>
                    <Insets bottom="20.0" left="30.0" right="20.0" top="20.0" />
                </VBox.margin>
            </TableView>
            
            <HBox spacing="10">
                <VBox.margin>
                    <Insets bottom="30.0" left="30.0" right="20.0" />
                </VBox.margin>
                <Button text="View Performance Stats" onAction="#handleViewStats" styleClass="card-action-btn"/>
                <Button text="Get Campaign Link" onAction="#handleGetLink" styleClass="card-action-btn-outline"/>
            </HBox>
        </children>
    </VBox>
    
    <VBox prefWidth="350.0" styleClass="card">
        <HBox.margin>
            <Insets bottom="30.0" right="30.0" top="30.0" left="10.0"/>
        </HBox.margin>
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <children>
            <Label text="Propose New Campaign" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                <VBox.margin>
                    <Insets bottom="25.0" />
                </VBox.margin>
            </Label>
            
            <VBox spacing="6">
                <Label text="CAMPAIGN TITLE" styleClass="front-form-label"/>
                <TextField fx:id="txtTitle" promptText="Enter title" styleClass="front-text-field"/>
            </VBox>
            
            <VBox spacing="6">
                <VBox.margin><Insets top="15.0" /></VBox.margin>
                <Label text="CAMPAIGN TYPE" styleClass="front-form-label"/>
                <ComboBox fx:id="cmbType" maxWidth="Infinity" styleClass="front-combo"/>
            </VBox>
            
            <VBox spacing="6">
                <VBox.margin><Insets top="15.0" /></VBox.margin>
                <Label text="TARGET URL" styleClass="front-form-label"/>
                <TextField fx:id="txtLinkUrl" promptText="https://yourwebsite.com" styleClass="front-text-field"/>
            </VBox>
            
            <VBox spacing="6">
                <VBox.margin><Insets top="15.0" /></VBox.margin>
                <Label text="CAMPAIGN MEDIA (IMAGE/VIDEO/POSTER)" styleClass="front-form-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="btnChooseFile" onAction="#handleChooseFile" text="📁  Choose File" styleClass="card-action-btn-outline" />
                    <Label fx:id="lblFileName" text="No file selected" style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;" />
                </HBox>
            </VBox>
            
            <HBox spacing="15">
                <VBox.margin><Insets top="15.0" /></VBox.margin>
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="START DATE" styleClass="front-form-label"/>
                    <DatePicker fx:id="dpStartDate" maxWidth="Infinity" styleClass="front-text-field"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label text="END DATE" styleClass="front-form-label"/>
                    <DatePicker fx:id="dpEndDate" maxWidth="Infinity" styleClass="front-text-field"/>
                </VBox>
            </HBox>
            
            <Button mnemonicParsing="false" onAction="#handleEstimatePrice" text="Estimate Cost" styleClass="card-action-btn-outline" maxWidth="Infinity">
                <VBox.margin><Insets top="20.0" /></VBox.margin>
            </Button>
            
            <Label fx:id="lblEstimatedPrice" text="" alignment="CENTER" maxWidth="Infinity">
                <VBox.margin><Insets top="10.0" bottom="15.0"/></VBox.margin>
            </Label>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <VBox alignment="CENTER" spacing="10.0">
                <children>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSubmit" text="Submit Proposal" styleClass="hero-cta-btn"/>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleClear" text="Clear Form" styleClass="front-nav-btn"/>
                </children>
            </VBox>
        </children>
    </VBox>

</HBox>
