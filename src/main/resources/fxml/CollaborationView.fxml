<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="768.0" prefWidth="774.0" stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CollaborationController">
    <children>
        <VBox prefHeight="768.0" prefWidth="500.0" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="title-label" text="Collaborations List">
                    <VBox.margin>
                        <Insets bottom="10.0" left="20.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <TableView fx:id="tableCollaborations" prefHeight="700.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                        <TableColumn fx:id="colTitle" prefWidth="120.0" text="Title" />
                        <TableColumn fx:id="colType" prefWidth="80.0" text="Type" />
                        <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
                        <TableColumn fx:id="colStartDate" prefWidth="90.0" text="Start Date" />
                        <TableColumn fx:id="colPrice" prefWidth="70.0" text="Price" />
                    </columns>
                    <VBox.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                    </VBox.margin>
                </TableView>
            </children>
        </VBox>
        <VBox prefHeight="768.0" prefWidth="250.0" styleClass="card">
            <HBox.margin>
                <Insets bottom="20.0" right="20.0" top="20.0" />
            </HBox.margin>
            <children>
                <Label styleClass="title-label" text="Manage">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>
                
                <Label text="Partner ID" />
                <TextField fx:id="txtPartnerId" promptText="Enter partner ID" />
                
                <Label text="Title">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtTitle" promptText="Enter title" />
                
                <Label text="Type">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <ComboBox fx:id="cmbType" maxWidth="1.7976931348623157E308" />
                
                <Label text="Link URL">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtLinkUrl" promptText="https://..." />
                

                <Label text="Start Date">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <DatePicker fx:id="dpStartDate" maxWidth="1.7976931348623157E308" />
                
                <Label text="End Date">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <DatePicker fx:id="dpEndDate" maxWidth="1.7976931348623157E308" />
                
                <Label text="Price">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>
                <TextField fx:id="txtPrice" promptText="0.00" />
                
                <HBox alignment="CENTER" prefHeight="50.0" prefWidth="200.0" spacing="10.0">
                    <VBox.margin>
                        <Insets top="30.0" />
                    </VBox.margin>
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleSave" prefWidth="90.0" styleClass="btn-primary" text="Save" />
                        <Button mnemonicParsing="false" onAction="#handleClear" prefWidth="80.0" text="Clear">
                            <styleClass>
                                <String fx:value="button" />
                            </styleClass>
                        </Button>
                    </children>
                </HBox>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-danger" text="Delete Selected">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</HBox>
