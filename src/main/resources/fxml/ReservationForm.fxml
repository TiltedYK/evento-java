<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ReservationFormController"
      styleClass="content-area"
      prefWidth="560" spacing="18">
    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

    <!-- Header -->
    <VBox spacing="4">
        <Label fx:id="formTitle" text="New Reservation" styleClass="form-title"/>
        <Label text="Link an event to a user and set the number of places." styleClass="page-subtitle"/>
        <Region prefHeight="3" prefWidth="80"
                style="-fx-background-color: linear-gradient(to right, #6366F1, transparent); -fx-background-radius: 2;"/>
    </VBox>

    <!-- Card -->
    <VBox styleClass="card" spacing="16">

        <GridPane hgap="16" vgap="13">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="EVENT" styleClass="field-label"/>
                <TextField fx:id="eventIdField" promptText="e.g. 1"/>
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="GUEST ACCOUNT" styleClass="field-label"/>
                <TextField fx:id="userIdField" promptText="e.g. 5"/>
            </VBox>

            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="NUMBER OF PLACES" styleClass="field-label"/>
                <Spinner fx:id="placesSpinner" editable="true" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="STATUS" styleClass="field-label"/>
                <ComboBox fx:id="statutCombo" maxWidth="Infinity"/>
            </VBox>
        </GridPane>

        <!-- Divider -->
        <Region prefHeight="1"
                style="-fx-background-color: #1C2133;"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancel" styleClass="btn-ghost" onAction="#onCancel"/>
            <Button fx:id="saveButton" text="💾  Save Reservation" styleClass="btn-success" onAction="#onSave"/>
        </HBox>
    </VBox>
</VBox>
