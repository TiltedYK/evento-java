<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.UserListController"
      spacing="22">
    <VBox spacing="3">
        <Label text="Users" styleClass="page-title"/>
        <Label text="Manage accounts and access" styleClass="page-subtitle"/>
    </VBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Search by name, email..." styleClass="search-field" prefWidth="320"/>
        <ComboBox fx:id="roleFilter" promptText="All roles" prefWidth="160"/>
        <ComboBox fx:id="stateFilter" promptText="All states" prefWidth="160"/>
        <Button text="Reset" styleClass="btn-ghost" onAction="#onReset"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New User" styleClass="btn-success" onAction="#onAdd"/>
    </HBox>
    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNom"     text="LAST NAME"  prefWidth="150"/>
            <TableColumn fx:id="colPrenom"  text="FIRST NAME" prefWidth="150"/>
            <TableColumn fx:id="colEmail"   text="EMAIL"      prefWidth="220"/>
            <TableColumn fx:id="colTel"     text="PHONE"      prefWidth="130"/>
            <TableColumn fx:id="colRole"    text="ROLE"       prefWidth="100"/>
            <TableColumn fx:id="colState"   text="STATE"      prefWidth="100"/>
            <TableColumn fx:id="colActions" text="ACTIONS"    prefWidth="160"/>
        </columns>
    </TableView>
</VBox>
