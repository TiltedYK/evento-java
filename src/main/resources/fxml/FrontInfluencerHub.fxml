<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FrontInfluencerHubController"
      styleClass="front-page" spacing="0" prefHeight="768.0" prefWidth="1024.0">

    <VBox styleClass="front-page-header" spacing="6">
        <Label text="🌟  INFLUENCER HUB" styleClass="front-page-title"/>
        <Label text="Browse campaigns, get your tracking links, and monitor your impact." styleClass="front-page-subtitle"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>
        
        <VBox prefWidth="600" HBox.hgrow="ALWAYS" spacing="15">
            <Label text="Active Campaigns to Promote" styleClass="title-label" style="-fx-font-size: 18px;"/>
            <TableView fx:id="tableCampaigns" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitle" prefWidth="200.0" text="Campaign Title" />
                    <TableColumn fx:id="colType" prefWidth="100.0" text="Type" />
                    <TableColumn fx:id="colPrice" prefWidth="100.0" text="Reward/Price" />
                </columns>
            </TableView>
            <HBox spacing="10">
                <Button text="Get My Referral Link" onAction="#handleGetLink" styleClass="card-action-btn"/>
            </HBox>
        </VBox>
        
        <VBox prefWidth="350" styleClass="card" spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="My Performance" styleClass="title-label" style="-fx-font-size: 18px;"/>
            
            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #2D2D3A; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="TOTAL CLICKS GENERATED" styleClass="promo-stat-key"/>
                <Label fx:id="lblTotalClicks" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #BB86FC;"/>
            </VBox>
            
            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #2D2D3A; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="CONVERSIONS" styleClass="promo-stat-key"/>
                <Label fx:id="lblConversions" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #03DAC6;"/>
            </VBox>
            
            <Label text="Hit Details" styleClass="subtitle-label" style="-fx-font-size: 14px;">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Label>
            
            <TableView fx:id="tableMyHits" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colHitDate" prefWidth="150.0" text="Date" />
                    <TableColumn fx:id="colHitSession" prefWidth="150.0" text="Session ID" />
                </columns>
            </TableView>
        </VBox>
    </HBox>

</VBox>
